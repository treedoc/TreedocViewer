{
  "name": "treedoc-viewer",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build:v1": "cd ../v1 && yarn install --ignore-engines && V1_SUBDIRECTORY=1 NODE_OPTIONS=--openssl-legacy-provider yarn build-app",
    "deploy:prepare": "yarn build && yarn build:v1 && cp -r ../v1/dist/app dist/v1",
    "deploy": "yarn deploy:prepare && gh-pages -d dist && gh-pages -d dist -r git@github.com:treedoc/treedoc.github.io.git -b master"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@primevue/themes": "^4.2.5",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "codemirror": "^6.0.1",
    "date-fns": "^4.4.0",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "splitpanes": "^4.1.2",
    "treedoc": "^0.3.51",
    "vue": "^3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.6.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "gh-pages": "^6.3.0",
    "jsdom": "^26.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.6",
    "vue-tsc": "^3.3.3"
  }
}